# =============================================================================
# Ingredient Scanner API — variables for Railway
# =============================================================================
# Add these in: Railway → your API service → Variables
# (or link a Railway Postgres plugin and reference its DATABASE_URL)
#
# This file is documentation only; it is not loaded by the app.
# Do not put real secrets in git — paste values only inside Railway.
# =============================================================================

# --- Required ---

# Postgres connection URI. Password must be URL-encoded (# @ : etc.).
# If you use Railway Postgres: add the plugin, then reference the variable
# Railway exposes (often named DATABASE_URL on the database service) on the
# API service, or copy the connection string here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- Recommended for production ---

NODE_ENV=production

# Railway usually injects PORT at runtime; you can omit this and the app
# listens on Railway’s assigned port. If unset, the API defaults to 8787.
# PORT=${{PORT}}

# Bind address (default in code is already 0.0.0.0 — safe for containers).
HOST=0.0.0.0

# --- Optional: Google Cloud Vision (OCR) ---

# Preferred on Railway: paste the full service account JSON as one line
# (Railway “Secret” type). Leave empty to run without OCR (DOM-only path).
GOOGLE_VISION_CREDENTIALS_JSON=

# Not used on Railway in most setups (no checked-in JSON file). Prefer JSON above.
GOOGLE_VISION_CREDENTIALS_FILE=

# --- Optional: extension authentication ---

# Comma-separated keys; extension may send x-api-key. Leave empty to allow
# unauthenticated analyze calls (lock this down if the API is public).
INGREDIENT_SCANNER_API_KEYS=

# --- Optional: logging / metadata ---

SERVICE_NAME=ingredient-scanner-api
