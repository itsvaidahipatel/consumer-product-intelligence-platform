# =============================================================================
# Consumer Product Intelligence API — Railway production variables
# =============================================================================
# Railway → your API service → Variables (paste values in the dashboard)
# Do NOT commit real secrets to git.
# =============================================================================

# --- Required ---

# Supabase: use **Transaction pooler** (port 6543), NOT direct db.*:5432
# Dashboard → Settings → Database → Connection string → Transaction pooler → URI
# Password must be URL-encoded (# → %23, etc.)
DATABASE_URL=postgresql://postgres.PROJECT_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

NODE_ENV=production
HOST=0.0.0.0
# PORT is injected by Railway automatically — do not hardcode

# --- Recommended: lock down the public API ---

# Generate: openssl rand -hex 24
# Extension options → API key (same value)
INGREDIENT_SCANNER_API_KEYS=your-generated-key-here

SERVICE_NAME=consumer-product-intelligence-api

# --- Google Vision (OCR) — required for image-only / incomplete DOM pages ---

# Paste entire cre.json as ONE line (Railway → Secret variable type)
# Local helper: node -e "console.log(JSON.stringify(require('./cre.json')))"
GOOGLE_VISION_CREDENTIALS_JSON=

# Do not use GOOGLE_VISION_CREDENTIALS_FILE on Railway (no file on disk)

# --- LLM (production: no Ollama on Railway by default) ---

LLM_SUMMARY=auto
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMS=384

# Leave Ollama unset unless you point to an external VPS:
# OLLAMA_BASE_URL=https://your-ollama-vps.example.com

# --- Optional: Neo4j Aura, Langfuse (skip for first deploy) ---

# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# =============================================================================
# After first deploy
# =============================================================================
# 1. Migrations (if not already applied to this DB):
#    Railway service → Shell:
#    corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm db:migrate
#
# 2. RAG seed (once per DB):
#    pnpm rag:seed
#
# 3. Health: GET https://YOUR-SERVICE.up.railway.app/ready
#
# 4. Extension options:
#    API URL = https://YOUR-SERVICE.up.railway.app
#    API key = same as INGREDIENT_SCANNER_API_KEYS
# =============================================================================
