{
  "manifest_version": 3,
  "name": "AI Scanner",
  "version": "0.3.0",
  "description": "AI-powered product ingredient analysis on supported e-commerce sites.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://*.up.railway.app/*",
    "https://www.amazon.in/*",
    "https://amazon.in/*",
    "https://www.nykaa.com/*",
    "https://www.myntra.com/*",
    "https://blinkit.com/*",
    "https://www.blinkit.com/*",
    "https://www.zeptonow.com/*",
    "https://*.amazonaws.com/*",
    "https://*.cloudfront.net/*",
    "https://*.akamaized.net/*",
    "https://images-na.ssl-images-amazon.com/*",
    "https://m.media-amazon.com/*"
  ],
  "action": {
    "default_title": "AI Scanner",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://amazon.in/*",
        "https://www.nykaa.com/*",
        "https://www.myntra.com/*",
        "https://blinkit.com/*",
    "https://www.blinkit.com/*",
        "https://www.zeptonow.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
