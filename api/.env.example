# Use a single URI. Password characters that are reserved in URLs must be percent-encoded
# (e.g. # → %23, @ → %40, : → %3A). Raw '#' in the password breaks parsing (ERR_INVALID_URL).
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ingredient_scanner

# Supabase — direct session mode (port 5432) can hit CONNECT_TIMEOUT from some cloud
# networks (IPv6, cold project, or routing). Prefer the **Transaction pooler** URI from
# Dashboard → Settings → Database → Connection string → **Transaction pooler** (port 6543,
# user often `postgres.<project-ref>`). Always add sslmode=require and percent-encode the password.
# Examples (placeholders only):
# DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://postgres.<project-ref>:ENCODED_PASSWORD@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
PORT=8787
HOST=0.0.0.0

# Optional: comma-separated keys accepted via the `x-api-key` header from the extension.
INGREDIENT_SCANNER_API_KEYS=

# Optional: Google Cloud Vision — service account JSON (pick one).
# Never commit real credentials.
# GOOGLE_VISION_CREDENTIALS_JSON={"type":"service_account",...}
# Or point at a local file. With `pnpm dev:api`, cwd is `api/`, so repo-root `cre.json` is:
# GOOGLE_VISION_CREDENTIALS_FILE=../cre.json
GOOGLE_VISION_CREDENTIALS_JSON=
GOOGLE_VISION_CREDENTIALS_FILE=

NODE_ENV=development
SERVICE_NAME=ingredient-scanner-api
